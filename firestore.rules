rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Catch-all deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      // In a real app, we check an admins collection. 
      // For this migration, we'll allow the specific user email or check a document.
      return isSignedIn() && (
        request.auth.token.email == 'gautructv2000@gmail.com' || 
        request.auth.token.email == 'adminfruithaven@gmail.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- Collections ---

    match /fruits/{fruitId} {
      allow read: if true;
      allow write: if true; // In a real app, restrict to Admin
    }

    match /news/{newsId} {
      allow read: if true;
      allow write: if true;
    }

    match /coupons/{couponId} {
      allow read: if true;
      allow write: if true;
    }

    match /orders/{orderId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if true;
    }

    match /users/{userId} {
      allow read: if true;
      allow write: if true;
    }

    match /bundles/{bundleId} {
      allow read: if true;
      allow write: if true;
    }

    match /chats/{sessionId} {
      allow read, write: if true;
      match /messages/{messageId} {
        allow read, write: if true;
      }
    }
  }
}
